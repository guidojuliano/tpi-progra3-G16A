<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<!-- Configuración de la cadena de conexión a la base de datos -->
	<connectionStrings>
		<add name="RestoBarDb"
			 connectionString="Server=localhost,1435;Database=RestoBarDb;User Id=sa;Password=RestoBar2026!;TrustServerCertificate=True;"
			 providerName="System.Data.SqlClient" />
		<!-- Para usar SQL Server Local (sin Docker), descomentar esta línea y comentar la de arriba -->
		<!--<add name="RestoBarDb"
			 connectionString="Server=.\SQLEXPRESS;Database=RestoBarDb;Integrated Security=True;"
			 providerName="System.Data.SqlClient" />-->
	</connectionStrings>

	<system.web>
		<globalization culture="es-AR" uiCulture="es-AR" />
		<compilation debug="true" targetFramework="4.8" />
		<httpRuntime targetFramework="4.8" />
		<customErrors mode="On" defaultRedirect="Error.aspx" />
	</system.web>
</configuration>

